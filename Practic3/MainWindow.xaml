<Window x:Class="Practic3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HTTP Monitor" Height="720" Width="1020" MinHeight="600" MinWidth="800">
    <Grid Margin="8">
        <TabControl>

            <!-- ═══ СЕРВЕР / МОНИТОРИНГ ═══ -->
            <TabItem Header="Сервер / Мониторинг">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="160"/>
                    </Grid.RowDefinitions>

                    <!-- Управление сервером -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                        <Label Content="Порт:" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtPort" Width="70" Text="8080" VerticalContentAlignment="Center"/>
                        <Button x:Name="BtnServer" Content="Запустить" Margin="6,0,0,0" Padding="10,4"
                                Click="BtnServer_Click"/>
                        <Button Content="Сохранить логи" Margin="6,0,0,0" Padding="10,4"
                                Click="BtnSaveLogs_Click"/>
                        <Separator Width="1" Background="Gray" Margin="8,2"/>
                        <Label Content="Фильтр:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CmbFilter" Width="80" SelectedIndex="0"
                                  SelectionChanged="CmbFilter_SelectionChanged">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                        </ComboBox>
                    </WrapPanel>

                    <!-- Статистика -->
                    <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#DDD"
                            BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,0,6">
                        <TextBlock x:Name="TxtStats"
                                   Text="GET: 0  |  POST: 0  |  Всего: 0  |  Среднее время: — мс"
                                   FontSize="12"/>
                    </Border>

                    <!-- Лог -->
                    <TextBox Grid.Row="2" x:Name="TxtLogs" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"
                             Margin="0,0,0,6"/>

                    <!-- График -->
                    <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <TextBlock Text="Запросов в минуту (последние 20):"
                                       Margin="6,4" FontSize="11" VerticalAlignment="Top"/>
                            <Canvas x:Name="ChartCanvas" Margin="0,22,4,4"
                                    SizeChanged="ChartCanvas_SizeChanged"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ КЛИЕНТ ═══ -->
            <TabItem Header="HTTP-Клиент">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- URL + метод + кнопка -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                        <Label Content="URL:" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtUrl" Width="400" VerticalContentAlignment="Center"
                                 Text="https://jsonplaceholder.typicode.com/posts"/>
                        <Label Content="Метод:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <ComboBox x:Name="CmbMethod" Width="80" SelectedIndex="0">
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                        </ComboBox>
                        <Button Content="Отправить запрос" Margin="8,0,0,0" Padding="10,4"
                                Click="BtnSend_Click"/>
                    </WrapPanel>

                    <Label Grid.Row="1" Content="Тело запроса (JSON):"/>
                    <TextBox Grid.Row="2" x:Name="TxtBody" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11" Margin="0,0,0,6"/>

                    <Label Grid.Row="3" Content="Ответ:"/>
                    <TextBox Grid.Row="4" x:Name="TxtResponse" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
